<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Joe's Burger - Torgelow</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Inter", sans-serif;
  }

  body {
    background: #0f0f0f;
    color: white;
  }

  /* NAV */
  nav {
    position: sticky;
    top: 0;
    background: rgba(20,20,20,0.9);
    backdrop-filter: blur(10px);
    display: flex;
    justify-content: space-between;
    padding: 15px 25px;
    z-index: 1000;
  }

  nav h1 {
    font-size: 18px;
    font-weight: 800;
    color: orange;
  }

  nav a {
    color: white;
    margin-left: 15px;
    text-decoration: none;
    font-weight: 500;
  }

  /* HERO */
  .hero {
    height: 70vh;
    background: url('https://images.unsplash.com/photo-1550547660-d9450f859349') center/cover;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero h2 {
    font-size: 3rem;
    font-weight: 800;
  }

  .hero p {
    margin-top: 10px;
    color: #ccc;
  }

  .btn {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 20px;
    background: orange;
    color: black;
    font-weight: bold;
    border-radius: 8px;
    text-decoration: none;
  }

  /* SECTIONS */
  section {
    padding: 60px 20px;
    max-width: 1000px;
    margin: auto;
  }

  h3 {
    font-size: 28px;
    margin-bottom: 20px;
  }

  /* MENU */
  .menu {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 15px;
  }

  .card {
    background: #1c1c1c;
    padding: 20px;
    border-radius: 12px;
    transition: 0.3s;
    border: 1px solid #2a2a2a;
  }

  .card:hover {
    transform: translateY(-5px);
    border-color: orange;
  }

  .price {
    color: orange;
    font-weight: 700;
    margin-top: 10px;
  }

  /* INFO */
  .info {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
  }

  .box {
    background: #1c1c1c;
    padding: 20px;
    border-radius: 12px;
  }

  footer {
    text-align: center;
    padding: 30px;
    background: #000;
    margin-top: 40px;
    color: #777;
  }
</style>
</head>

<body>

<nav>
  <h1>🍔 Joe's Burger</h1>
  <div>
    <a href="#menu">Menu</a>
    <a href="#about">About</a>
    <a href="#contact">Contact</a>
  </div>
</nav>

<div class="hero">
  <div class="hero-content">
    <h2>Fresh Burgers in Torgelow</h2>
    <p>Fast • Cheap • Delicious</p>
    <a class="btn" href="#menu">View Menu</a>
  </div>
</div>

<section id="menu">
  <h3>🍔 Menu</h3>
  <div class="menu">

    <div class="card">
      <h4>Cheeseburger</h4>
      <p>Classic beef burger with cheese</p>
      <div class="price">€4.30</div>
    </div>

    <div class="card">
      <h4>BBQ Burger</h4>
      <p>Smoky BBQ sauce & crispy onions</p>
      <div class="price">€5.00</div>
    </div>

    <div class="card">
      <h4>Chili Cheese</h4>
      <p>Spicy & cheesy favorite</p>
      <div class="price">€4.80</div>
    </div>

    <div class="card">
      <h4>XXL Burger</h4>
      <p>Extra large double meat burger</p>
      <div class="price">€5.50</div>
    </div>

  </div>
</section>

<section id="about">
  <h3>About Us</h3>
  <p style="color:#bbb; line-height:1.6;">
    Joe's Burger in Torgelow is a local favorite for fresh, affordable fast food.
    We focus on quality ingredients, fast service, and great taste at low prices.
  </p>
</section>

<section id="contact">
  <h3>📍 Visit Us</h3>

  <div class="info">
    <div class="box">
      <h4>Address</h4>
      <p>Mozartstraße 10, Torgelow</p>
    </div>

    <div class="box">
      <h4>Phone</h4>
      <p>03976 2579976</p>
    </div>

    <div class="box">
      <h4>Hours</h4>
      <p>Mon–Sun: 11:00 – 21:00</p>
    </div>
  </div>

  <a class="btn" style="margin-top:20px;" 
     href="https://www.google.com/maps?q=Mozartstraße+10+Torgelow" target="_blank">
    Open in Maps
  </a>
</section>

<footer>
  © 2026 Joe's Burger - Torgelow
</footer>

</body>
</html>
